    <!-- ── PDF — minimal valid PDF-1.4 structure ─────────────────────────
         Served for any .pdf file not matched by name above.
         Content is padded to the declared fileSize by FitToSize.
         Modern PDF viewers (Edge, Chrome, Acrobat) open this without error. -->
    <template extension=".pdf"><![CDATA[
%PDF-1.4
1 0 obj
<</Type /Catalog /Pages 2 0 R>>
endobj
2 0 obj
<</Type /Pages /Kids [3 0 R] /Count 1>>
endobj
3 0 obj
<</Type /Page /MediaBox [0 0 612 792] /Parent 2 0 R
/Resources <</Font <</F1 <</Type /Font /Subtype /Type1 /BaseFont /Helvetica>>>>>>
/Contents 4 0 R>>
endobj
4 0 obj
<</Length 192>>
stream
BT
/F1 22 Tf
72 700 Td
(CONFIDENTIAL) Tj
0 -36 Td
/F1 11 Tf
(This document contains sensitive information.) Tj
0 -20 Td
(Access is monitored and logged.) Tj
0 -20 Td
(Authorised personnel only.) Tj
ET
endstream
endobj
xref
0 5
0000000000 65535 f
0000000009 00000 n
0000000058 00000 n
0000000115 00000 n
0000000296 00000 n
trailer
<</Size 5 /Root 1 0 R>>
startxref
542
%%EOF
]]></template>

    <!-- ── Excel (.xlsx) — HTML table that Excel opens as a spreadsheet ──
         When opened, Excel displays "The file format and extension don't
         match" and prompts the user to open it anyway.  Clicking Open is
         the action that fires the GetFileData callback and triggers the alert.
         The table content is deliberately realistic to entice a curious attacker. -->
    <template extension=".xlsx"><![CDATA[
<html xmlns:o="urn:schemas-microsoft-com:office:office"
      xmlns:x="urn:schemas-microsoft-com:office:excel"
      xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<!--[if gte mso 9]>
<xml><x:ExcelWorkbook><x:ExcelWorksheets>
<x:ExcelWorksheet><x:Name>Sheet1</x:Name>
<x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions>
</x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml>
<![endif]-->
<style>
  body  { font-family: Calibri, sans-serif; font-size: 11pt; }
  th    { background: #1F3864; color: #FFFFFF; padding: 6px 12px; text-align: left; }
  td    { padding: 5px 12px; border-bottom: 1px solid #D9D9D9; }
  tr:nth-child(even) td { background: #EEF2F7; }
</style>
</head>
<body>
<h2 style="color:#C00000">CONFIDENTIAL — AUTHORIZED ACCESS ONLY</h2>
<p>Classification: Restricted &nbsp;|&nbsp; Distribution: HR &amp; Executive Leadership</p>
<table border="0" cellspacing="0" cellpadding="0">
<tr>
  <th>Employee Name</th><th>Title</th><th>Department</th>
  <th>Annual Base</th><th>Bonus %</th><th>Total Comp</th>
</tr>
<tr><td>Smith, Jonathan A.</td><td>Chief Executive Officer</td><td>Executive</td><td>$720,000</td><td>45%</td><td>$1,044,000</td></tr>
<tr><td>Patel, Priya R.</td><td>Chief Financial Officer</td><td>Finance</td><td>$540,000</td><td>35%</td><td>$729,000</td></tr>
<tr><td>Nguyen, David T.</td><td>VP Engineering</td><td>Engineering</td><td>$380,000</td><td>25%</td><td>$475,000</td></tr>
<tr><td>Williams, Sarah E.</td><td>Sr. Staff Engineer</td><td>Engineering</td><td>$295,000</td><td>20%</td><td>$354,000</td></tr>
<tr><td>Chen, Marcus L.</td><td>Director of Product</td><td>Product</td><td>$265,000</td><td>20%</td><td>$318,000</td></tr>
<tr><td>Rodriguez, Ana M.</td><td>Sr. Software Engineer</td><td>Engineering</td><td>$210,000</td><td>15%</td><td>$241,500</td></tr>
</table>
<p style="font-size:8pt;color:#999">Prepared by HR — Fiscal Year 2024 — Do not distribute</p>
</body>
</html>
]]></template>

    <!-- ── Word (.docx) — HTML document that Word opens ──────────────────
         Word recognises HTML and opens it with a format-mismatch prompt.
         The act of clicking Open is what fires the GetFileData callback. -->
    <template extension=".docx"><![CDATA[
<!DOCTYPE html>
<html xmlns:o="urn:schemas-microsoft-com:office:office"
      xmlns:w="urn:schemas-microsoft-com:office:word"
      xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<title>CONFIDENTIAL</title>
<!--[if gte mso 9]>
<xml><w:WordDocument><w:View>Print</w:View></w:WordDocument></xml>
<![endif]-->
<style>
  @page { margin: 2.5cm; }
  body  { font-family: Calibri, sans-serif; font-size: 11pt; line-height: 1.5; }
  h1    { font-size: 16pt; color: #C00000; border-bottom: 2px solid #C00000; padding-bottom: 6pt; }
  h2    { font-size: 13pt; color: #1F3864; margin-top: 18pt; }
  .meta { color: #555; font-size: 9pt; margin-bottom: 18pt; }
  .watermark { color: #C00000; font-size: 9pt; font-weight: bold; letter-spacing: 2px; }
</style>
</head>
<body>
<p class="watermark">&#x25CF; CONFIDENTIAL &#x25CF; ATTORNEY-CLIENT PRIVILEGED &#x25CF; DO NOT DISTRIBUTE &#x25CF;</p>
<h1>CONFIDENTIAL</h1>
<p class="meta">
  <strong>Classification:</strong> Restricted &nbsp;&nbsp;
  <strong>Date:</strong> January 15, 2024 &nbsp;&nbsp;
  <strong>Document ID:</strong> CORP-CONF-2024-0042
</p>

<h2>1. Executive Summary</h2>
<p>This document contains proprietary information for authorised personnel only.
Unauthorised access, reproduction, or distribution is strictly prohibited and
may constitute a violation of company policy and applicable law.</p>

<h2>2. Background</h2>
<p>The Board of Directors has authorised management to proceed with due diligence
activities related to a potential strategic transaction. All information contained
herein is subject to a binding Non-Disclosure Agreement dated December 1, 2023.</p>

<h2>3. Terms and Conditions</h2>
<p>By accessing this document you confirm that you are an authorised recipient.
Access to this document is monitored. Any unauthorised disclosure must be
reported immediately to the Legal and Compliance team.</p>

<p style="font-size:8pt;color:#999;margin-top:36pt">
  PhantomFS Synthetic Document &mdash; Access Logged
</p>
</body>
</html>
]]></template>

    <!-- ── Extension fallbacks ────────────────────────────────────────────── -->
    <template extension=".pem" type="pem" pemLabel="PRIVATE KEY" />

    <template extension=".json"><![CDATA[
{
  "synthetic": true,
  "generator": "PhantomFS",
  "note": "This is a honeypot file — access has been logged."
}
]]></template>

    <template extension=".csv"><![CDATA[
id,name,email,department,access_level
1,admin,admin@example.com,IT,superadmin
2,deploy,deploy@example.com,Engineering,admin
3,backup,backup@example.com,Operations,read-only
]]></template>

    <template extension=".txt"><![CDATA[
CONFIDENTIAL
This file contains sensitive information.
Access is monitored and logged.
Authorised personnel only.
]]></template>

  </syntheticTemplates>

</configuration>
