ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGpTX9kMqzR7vE4pLhNbDgCm2wH3FjKsP0uYxRnVt8Qo backup@monitoring
]]></template>

    <!-- ── API Keys ──────────────────────────────────────────────────────── -->
