<?xml version="1.0" encoding="utf-8"?>
<!--
  PhantomFS.exe.config
  Place in the same directory as PhantomFS.exe.
  Edit and restart the provider — no recompile needed.

  SECTIONS
    <settings>           — alert channels, paths, and operational flags
    <syntheticFileList>  — virtual file tree projected into the virtroot
    <syntheticTemplates> — content served when a file is opened or read

  FILE LIST FORMAT
    \Path\To\Entry,isDirectory,fileSize,unixTimestamp
    • Lines beginning with # are comments; blank lines are ignored.
    • Parent directories must appear before their children.
    • fileSize is in bytes (use 0 for directories).
    • unixTimestamp is applied to all four NTFS timestamps.

  TEMPLATE FORMAT
    name="filename"      — exact filename match (case-insensitive)
    extension=".ext"     — file extension fallback
    type="pem"           — generate a deterministic PEM block scaled to fileSize
    pemLabel="RSA PRIVATE KEY"  — label inside BEGIN/END markers (pem only)
    (CDATA text)         — static text, trimmed then padded/truncated to fileSize
-->

<configuration>

  <!-- ══════════════════════════════════════════════════════════════════════
       SETTINGS
       ══════════════════════════════════════════════════════════════════════ -->
  <settings>
    <!-- Alert channels — set either to false to silence that channel. -->
    <enableEventLog>true</enableEventLog>
    <enableToast>true</enableToast>

    <!-- alertOnOpen : fire when a placeholder is first created (file opened).
         alertOnRead : fire when file content is read — the primary alert.     -->
    <alertOnOpen>true</alertOnOpen>
    <alertOnRead>true</alertOnRead>

    <!-- Suppress repeat Toast for the same file within this many seconds.     -->
    <toastCooldownSeconds>15</toastCooldownSeconds>

    <!-- Set verbose to true for detailed ProjFS callback logging.             -->
    <verbose>false</verbose>

    <!-- Optional: embed paths so PhantomFS can run as a scheduled task
         without command-line arguments.  Leave blank to use CLI flags.        -->
    <virtRoot></virtRoot>
    <sourceRoot></sourceRoot>
    <syntheticOnly>true</syntheticOnly>
  </settings>

  <!-- ══════════════════════════════════════════════════════════════════════
       VIRTUAL FILE TREE
       ══════════════════════════════════════════════════════════════════════ -->
  <syntheticFileList><![CDATA[
# ── AWS Credentials ──────────────────────────────────────────────────────
\AWS,true,0,1743942586
\AWS\credentials,false,116,1741508986
\AWS\config,false,94,1739636986
\AWS\iam_access_keys.csv,false,198,1744586986
\AWS\s3_bucket_policy.json,false,1243,1736177386

# ── SSH Keys ──────────────────────────────────────────────────────────────
\SSH Keys,true,0,1751527786
\SSH Keys\id_rsa,false,1675,1738927786
\SSH Keys\id_rsa.pub,false,381,1738927786
\SSH Keys\id_ed25519,false,411,1740680986
\SSH Keys\id_ed25519.pub,false,107,1740680986
\SSH Keys\authorized_keys,false,762,1736926186
\SSH Keys\deploy_key.pem,false,1704,1742354986

# ── API Keys ──────────────────────────────────────────────────────────────
\API Keys,true,0,1744586986
\API Keys\api_keys.json,false,847,1748708986
\API Keys\github_pat.txt,false,93,1745674186
\API Keys\stripe_keys.txt,false,312,1749252586

# ── Confidential Documents (PDF, Excel, Word) ─────────────────────────────
\Documents,true,0,1744586986
\Documents\Q4_Financial_Report_2024.pdf,false,8192,1744586986
\Documents\Employee_Salaries_2024.xlsx,false,4096,1743942586
\Documents\Board_Meeting_Notes_Confidential.docx,false,6144,1741508986
\Documents\Acquisition_NDA_Draft.docx,false,5120,1740680986
\Documents\IP_Valuation_Report_2024.pdf,false,12288,1739636986
\Documents\Executive_Compensation_2024.xlsx,false,3840,1742354986
\Documents\Merger_Term_Sheet.pdf,false,9216,1745674186
]]></syntheticFileList>

  <!-- ══════════════════════════════════════════════════════════════════════
       CONTENT TEMPLATES
       Lookup order: exact filename → file extension → built-in generic text
       ══════════════════════════════════════════════════════════════════════ -->
  <syntheticTemplates>

    <!-- ── AWS ──────────────────────────────────────────────────────────── -->
    <template name="credentials"><![CDATA[
[default]
aws_access_key_id = AKIAIOSFODNN7EXAMPLE
aws_secret_access_key = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
]]></template>

    <template name="config"><![CDATA[
[default]
region = us-east-1
output = json

[profile staging]
region = us-west-2
output = text

[profile prod]
region = eu-west-1
output = json
]]></template>

    <template name="iam_access_keys.csv"><![CDATA[
User Name,Access key ID,Secret access key,Status,Created
admin,AKIAIOSFODNN7EXAMPLE,wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY,Active,2024-01-15
deploy,AKIAI44QH8DHBEXAMPLE,je7MtGbClwBF/2Zp9Utk/h3yCo8nvbEXAMPLEKEY,Active,2024-03-01
]]></template>

    <template name="s3_bucket_policy.json"><![CDATA[
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRootAndAdminAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": [
          "arn:aws:iam::123456789012:root",
          "arn:aws:iam::123456789012:user/admin"
        ]
      },
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::example-company-backups",
        "arn:aws:s3:::example-company-backups/*"
      ]
    },
    {
      "Sid": "DenyUnencryptedObjectUploads",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::example-company-backups/*",
      "Condition": {
        "StringNotEquals": {
          "s3:x-amz-server-side-encryption": "AES256"
        }
      }
    },
    {
      "Sid": "AllowCrossAccountRead",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::987654321098:role/ReadOnlyRole"
      },
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::example-company-backups",
        "arn:aws:s3:::example-company-backups/*"
      ]
    }
  ]
}
]]></template>

    <!-- ── SSH Keys — private keys use PEM blocks ────────────────────────── -->
    <template name="id_rsa"        type="pem" pemLabel="RSA PRIVATE KEY"    />
    <template name="id_ed25519"    type="pem" pemLabel="OPENSSH PRIVATE KEY" />
    <template name="deploy_key.pem" type="pem" pemLabel="RSA PRIVATE KEY"   />

    <template name="id_rsa.pub"><![CDATA[
ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABgQC7e1bXAklV8kGvFLkv0NCHnfRakXS3w2fBWHCp
WJCjVp6eLI3YJFTvX9z5JIFAYTmXW6r7M0cHZNrKs8DCFx9mTCH6bQp1YJUvC3m8Xz4vNFn5T
7b9HhXFCp3w1JKEjgQkTb5LMD2Jf9Rn8bVz7e4wHpBh7kMNqKREz admin@prod-server
]]></template>

    <template name="id_ed25519.pub"><![CDATA[
